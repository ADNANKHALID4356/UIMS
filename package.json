{
  "name": "enterprise-inventory-system",
  "version": "2.0.0",
  "description": "Universal Enterprise Inventory Management System - Desktop Application",
  "main": "dist/backend/main.js",
  "homepage": "./",
  "author": "Development Team",
  "license": "PROPRIETARY",
  "private": true,
  "scripts": {
    "dev": "npm run server",
    "dev:app": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "server": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "babel src --out-dir dist --watch --source-maps --ignore src/frontend/**",
    "dev:frontend": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron . --dev",
    "build": "npm run build:backend && npm run build:frontend && npm run copy:assets",
    "build:backend": "babel src --out-dir dist --source-maps --ignore src/frontend/**",
    "build:frontend": "vite build",
    "copy:assets": "node -e \"require('fs').copyFileSync('assets/logo.png', 'dist/frontend/logo.png')\"",
    "electron": "electron .",
    "start": "npm run build && electron .",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win --x64",
    "package:portable": "npm run build && electron-builder --win portable --x64",
    "package:dir": "npm run build && electron-builder --dir",
    "cleanup:data": "node scripts/cleanup_user_data.js",
    "reset:password": "electron scripts/electron-reset-password.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .js,.jsx",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css}\""
    ,
    "sync:server": "node scripts/sync-server.js"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@mapbox/node-pre-gyp": "^2.0.3",
    "@reduxjs/toolkit": "^1.9.7",
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.5.0",
    "better-sqlite3-multiple-ciphers": "^12.6.2",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "exceljs": "^3.4.0",
    "html2canvas": "^1.4.1",
    "joi": "^17.11.0",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.1.3",
    "react-router-dom": "^6.20.0",
    "redux": "^4.2.1",
    "sql.js": "^1.10.2",
    "sqlite3": "^6.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.4",
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/preset-react": "^7.23.3",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "babel-plugin-module-resolver": "^5.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^2.0.0",
    "electron-rebuild": "^2.0.3",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "systeminformation": "^5.21.20",
    "tailwindcss": "^3.3.6",
    "vite": "^7.3.2",
    "wait-on": "^9.0.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "build": {
    "appId": "com.enterprise.inventory",
    "productName": "Enterprise Inventory System",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/icon.ico",
      "assets/logo.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon-256.png",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Enterprise Inventory System",
      "uninstallDisplayName": "Enterprise Inventory System",
      "license": "LICENSE.txt",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "menuCategory": true,
      "differentialPackage": false
    },
    "portable": {
      "artifactName": "${productName}-Portable.exe"
    }
  }
}
