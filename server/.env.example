PORT=8788
DATABASE_URL=postgres://user:pass@localhost:5432/uims
JWT_SECRET=change-me
PUBLIC_WEB_BASE_URL=https://uims.ummahtechinnovations.com
PGSSLMODE=disable

# PayFast Pakistan (Hosted checkout)
# NOTE: These are needed only when enabling real PayFast checkout.
PAYFASTPK_MODE=sandbox
PAYFASTPK_API_URL=https://api.payfast.com
PAYFASTPK_SANDBOX_URL=https://sandbox.payfast.com
PAYFASTPK_GRANT_TYPE=client_credentials
PAYFASTPK_MERCHANT_ID=
PAYFASTPK_MERCHANT_NAME=
PAYFASTPK_SECURED_KEY=
PAYFASTPK_SUCCESS_URL=https://uims.ummahtechinnovations.com/checkout/success
PAYFASTPK_FAILURE_URL=https://uims.ummahtechinnovations.com/checkout/failure

